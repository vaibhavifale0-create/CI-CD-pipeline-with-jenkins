pipeline {
    agent any

    stages {
        stage('Clone Code') {
            steps {
                git 'https://github.com/vaibhavifale0-create/CI-CD-pipeline-with-jenkins.git'
            }
        }

        stage('Install Dependencies') {
            steps {
                bat 'npm install'   // use sh for Linux
            }
        }

        stage('Run Application') {
            steps {
                bat 'npm start'
            }
        }
    }
}
